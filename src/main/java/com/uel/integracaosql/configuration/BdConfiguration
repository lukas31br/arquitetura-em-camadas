package com.uel.integracaosql.configuration;

import javax.sql.DataSource;

import org.springframework.beans.factory.annotation.Value;

import org.springframework.context.annotation.Bean;

import org.springframework.context.annotation.Configuration;

import org.springframework.jdbc.datasource.DriverManagerDataSource;

@Configuration //Informa ao spring que beans serão criados.

public class BdConfiguration{ // Classe com o nome do arquivo

    @Value("${spring.datasource.driver-class-name}")
    private String driverclass;

    @Value("${spring.datasource.url}")
    private String url;

    @Value("${spring.datasource.username}")
    private String username;

    @Value("${spring.datasource.password}")
    private String password;

    @Bean // O  bean serve para registrar os objetos criados e guardar o retorno na memória, além de executá-los

    public DataSource datasource(){ // Cria-se um objeto da classe Data Source(usada para fazer a conexão do service com o banco de dados)

        DriverManagerDataSource datasource = new DriverManagerDataSource();// Instacia-se na memória o objeto criado

        datasource.setDriverClassName(driverclass); // Informa o banco que será usado

        datasource.setUrl(url); // Informa o endereço até o projeto dentro do SGBD usado

        datasource.setUsername(username); // Informa qual o user de onde está presente o banco de dados

        datasource.setPassword(password); // Informa a senha desse usuário

        return datasource; // retorna para o bean alocar na memória

    }

}

